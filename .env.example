# ───────────────────────────────────────────────────
# Portfolio Backend — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ───────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=production
ALLOWED_ORIGIN=https://yourdomain.com

# SMTP (Gmail example — use an App Password)
# Generate one at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=your_app_password_here

# Contact routing
CONTACT_TO_EMAIL=your.email@example.com       # Where you receive messages
CONTACT_FROM_EMAIL=your.gmail@gmail.com        # The "from" address in the email
